# ══════════════════════════════════════
# PMarb — Cross-Market Prediction Arb
# ══════════════════════════════════════

# ─── Polymarket (Polygon) ───
# Wallet private key (from MetaMask — NEVER share)
POLY_PRIVATE_KEY=
POLY_WALLET_ADDRESS=
POLY_RPC=https://polygon-bor-rpc.publicnode.com
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Relayer API (create at polymarket.com → Settings → API Keys)
POLY_RELAYER_API_KEY=
POLY_RELAYER_ADDRESS=

# ─── Interactive Brokers ───
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
# 4001 = live, 4002 = paper
IBKR_CLIENT_ID=1

# ─── Sentiment (RSS Feeds) ───
# Google News RSS — real-time geopolitical keyword monitoring
SENTIMENT_RSS_URLS=https://news.google.com/rss/search?q=iran+ceasefire+OR+iran+strike+OR+hormuz+blockade&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=oil+supply+disruption+OR+hormuz+OR+tanker+attack&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=site:reuters.com+iran+OR+hormuz+OR+oil+sanctions&hl=en-US&gl=US&ceid=US:en
SENTIMENT_POLL_INTERVAL=30

# ─── EIA ───
# Register free at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=
# Key arrives instantly via email

# ─── Risk Limits ───
MAX_SESSION_LOSS_USD=500
MAX_SINGLE_POSITION_USD=1000
MAX_LOCKED_CAPITAL_USD=5000
MAX_POSITIONS=10

# ─── Mode ───
DRY_RUN=true
LOG_LEVEL=INFO
